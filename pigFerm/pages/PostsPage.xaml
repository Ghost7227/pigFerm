<Page x:Class="pigFerm.pages.PostsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PostsPage">

    <TabControl>
        <TabItem Header="Отделы">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Button Name="addNewDepartamentBtn" Content="Добавить новый отдел" Click="addNewDepartamentBtn_Click"/>

                <ListView Name="DepartamentListView" Grid.Row="1" Grid.IsSharedSizeScope="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="col"/>
                                    <ColumnDefinition SharedSizeGroup="col1"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding id}"/>
                                <TextBlock Text="{Binding nameDepartment}" Grid.Column="1"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabItem>
        <TabItem Header="Должности">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Button Name="addNewPostBtn" Click="addNewPostBtn_Click" Content="Добавить должность"/>

                <ListView Name="PostsListView" Grid.Row="1" Grid.IsSharedSizeScope="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="col"/>
                                    <ColumnDefinition SharedSizeGroup="col1"/>
                                    <ColumnDefinition SharedSizeGroup="col2"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding id}"/>
                                <TextBlock Text="{Binding namePost}" Grid.Column="1"/>
                                <TextBlock Text="{Binding salary}" Grid.Column="2"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
