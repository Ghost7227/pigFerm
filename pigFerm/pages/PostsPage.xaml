<Page x:Class="pigFerm.pages.PostsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PostsPage">

    <TabControl>
        <TabItem Header="Отделы">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Button Name="addNewDepartamentBtn" Content="Добавить новый отдел" Click="addNewDepartamentBtn_Click"/>

                <ListView Name="DepartamentListView" Grid.Row="1">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=id}"/>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=nameDepartment}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </TabItem>
        <TabItem Header="Должности">
            <Grid>
                <ListView Name="PostsListView">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=id}"/>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=namePost}"/>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=salary}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
