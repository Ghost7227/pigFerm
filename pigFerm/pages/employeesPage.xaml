<Page x:Class="pigFerm.pages.employeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="employeesPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Добавить сотрудника" Name="addNewEmployeeBtn" Click="addNewEmployeeBtn_Click"/>

        </StackPanel>

        <ListView Name="employeeLV" Grid.Row="1" Grid.IsSharedSizeScope="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition SharedSizeGroup="col"/>
                            <ColumnDefinition SharedSizeGroup="col1"/>
                            <ColumnDefinition SharedSizeGroup="col2"/>
                            <ColumnDefinition SharedSizeGroup="col3"/>
                            <ColumnDefinition SharedSizeGroup="col4"/>
                            <ColumnDefinition SharedSizeGroup="col5"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding id}" VerticalAlignment="Center" Grid.RowSpan="2"/>

                        <TextBlock Text="{Binding fio}" Grid.Column="1"/>

                        <TextBlock Text="{Binding birthday, StringFormat='dd.MM.yyyy'}" Grid.Column="1" Grid.Row="1"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="Пол: "/>
                            <TextBlock Text="{Binding gender}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Должность: "/>
                            <TextBlock Text="{Binding post.namePost}"/>
                        </StackPanel>

                        <Grid Grid.Column="3" Grid.RowSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition SharedSizeGroup="icol"/>
                                <ColumnDefinition SharedSizeGroup="icol1"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Паспорт: "/>
                            <TextBlock Text="{Binding pasport}" Grid.Column="1"/>
                            <TextBlock Text="ИНН: " Grid.Row="1"/>
                            <TextBlock Text="{Binding inn}" Grid.Row="1" Grid.Column="1"/>
                        </Grid>

                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                            <TextBlock Text="СНИЛС: "/>
                            <TextBlock Text="{Binding snils}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="5" Orientation="Horizontal">
                            <TextBlock Text="Номер телефона: "/>
                            <TextBlock Text="{Binding phone}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Эл. почта: "/>
                            <TextBlock Text="{Binding emailCor}"/>
                        </StackPanel>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
