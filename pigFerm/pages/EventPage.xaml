<Page x:Class="pigFerm.pages.EventPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EventPage">

    <Grid>
        <TabControl>
            <TabItem Header="События">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Button Name="addNewEventBtn" Content="Добавить событие" Click="addNewEventBtn_Click"/>
                    
                    <ListView Name="eventLV" Grid.Row="1" Grid.IsSharedSizeScope="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition SharedSizeGroup="col"/>
                                        <ColumnDefinition SharedSizeGroup="col1"/>
                                        <ColumnDefinition SharedSizeGroup="col2"/>
                                        <ColumnDefinition SharedSizeGroup="col3"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding id}"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Дата и время: "/>
                                        <TextBlock Text="{Binding dateTime}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Тип: "/>
                                        <TextBlock Text="{Binding EventType.nameEvent}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="Описание: "/>
                                        <TextBlock Text="{Binding descriiption}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>
            <TabItem Header="Типы событий">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Button Name="addNewTypeEventBtn" Content="Добавить тип событий" Click="addNewTypeEventBtn_Click"/>

                    <ListView Name="eventTypeLV" Grid.Row="1" Grid.IsSharedSizeScope="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition SharedSizeGroup="col"/>
                                        <ColumnDefinition SharedSizeGroup="col1"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding id}"/>
                                    <TextBlock Text="{Binding nameEvent}" Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
