<Page x:Class="pigFerm.pages.CounterpartiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CounterpartiesPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Button Name="addNewConterpartyBtn" Content="Добавить нового контрагента" Click="addNewConterpartyBtn_Click"/>

        <ListView Name="counterpartyLV" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="7*"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding id}"/>

                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                            <TextBlock Text="Название: "/>
                            <TextBlock Text="{Binding nameCounterparties}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="2">
                            <TextBlock Text="Постоянность: "/>
                            <TextBlock Text="{Binding isRegular}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="3">
                            <TextBlock Text="Адрес: "/>
                            <TextBlock Text="{Binding adres}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Описание: "/>
                            <TextBlock Text="{Binding description}"/>
                        </StackPanel>

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
