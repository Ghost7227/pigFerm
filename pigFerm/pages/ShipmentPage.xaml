<Page x:Class="pigFerm.pages.ShipmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShipmentPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Button Name="addShipmentBtn" Click="addShipmentBtn_Click" Content="Создать поставку"/>

        <ListView Grid.Row="1" Grid.IsSharedSizeScope="True" Name="shipmentLV">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition SharedSizeGroup="col"/>
                            <ColumnDefinition SharedSizeGroup="col1"/>
                            <ColumnDefinition SharedSizeGroup="col2"/>
                            <ColumnDefinition SharedSizeGroup="col3"/>
                            <ColumnDefinition SharedSizeGroup="col4"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding id}" Grid.Column="0"/>
                        <TextBlock Text="{Binding counterparty.nameCounterparties}" Grid.Column="1"/>
                        <TextBlock Text="{Binding date}" Grid.Column="2"/>
                        <TextBlock Text="{Binding sum, StringFormat='0.00 руб.'}" Grid.Column="3"/>
                        <TextBlock Text="{Binding }" Grid.Column="4"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
