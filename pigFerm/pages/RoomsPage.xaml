<Page x:Class="pigFerm.pages.RoomsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoomsPage">
    <TabControl>
        <TabItem Header="Помещения">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="29*"/>
                    <ColumnDefinition Width="368*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <ListView Name="roomsLV" Grid.Row="1" Grid.ColumnSpan="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="5*"/>
                                    <ColumnDefinition Width="5*"/>
                                    <ColumnDefinition Width="10*"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding id}"/>

                                <StackPanel Orientation="Horizontal" Grid.Column="1">
                                    <TextBlock Text="Тип: "/>
                                    <TextBlock Text="{Binding roomType.nameRoomTtpes}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Grid.Column="2">
                                    <TextBlock Text="Адрес: "/>
                                    <TextBlock Text="{Binding adres}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Заполнено "/>
                                        <TextBlock Text="{Binding currentCount}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="из "/>
                                        <TextBlock Text="{Binding capacity}"/>
                                        <TextBlock Text=" мест"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="{Binding locationNotes}" Grid.Column="3"/>
                                
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button Name="addNewRoom" Content="Добавить новое помещение" Click="addNewRoom_Click" Grid.ColumnSpan="2"/>
            </Grid>
        </TabItem>
        <TabItem Header="Типы помещений">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="43*"/>
                    <ColumnDefinition Width="11*"/>
                    <ColumnDefinition Width="18*"/>
                    <ColumnDefinition Width="722*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <ListView Name="roomTypesLV" Grid.Row="1" Grid.ColumnSpan="4">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding id}"/>
                                <TextBlock Text="{Binding nameRoomTtpes}" Grid.Column="1"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button Name="addNewRoomType" Content="Добавить новый тип" Click="addNewRoomType_Click" Grid.ColumnSpan="4"/>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
