<Page x:Class="pigFerm.pages.RoomsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pigFerm.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoomsPage">
    <TabControl>
        <TabItem Header="Помещения">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <ListView Name="roomsLV" Grid.Row="1" DisplayMemberPath="roomType.nameRoomTtpes">

                </ListView>
                <Button Name="addNewRoom" Content="Добавить новое помещение" Click="addNewRoom_Click"/>
            </Grid>
        </TabItem>
        <TabItem Header="Типы помещени1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="43*"/>
                    <ColumnDefinition Width="11*"/>
                    <ColumnDefinition Width="18*"/>
                    <ColumnDefinition Width="722*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <ListView Name="roomTypesLV" Grid.Row="1" DisplayMemberPath="roomType.nameRoomTtpes" Grid.ColumnSpan="4">

                </ListView>
                <Button Name="addNewRoomType" Content="Добавить новый тип" Click="addNewRoomType_Click" Grid.ColumnSpan="4"/>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
