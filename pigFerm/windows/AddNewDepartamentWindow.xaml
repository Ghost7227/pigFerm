<Window x:Class="pigFerm.windows.AddNewDepartamentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="AddNewDepartamentWindow" Height="100" Width="200">
    <Grid>
        <StackPanel>
            <TextBlock Text="Введите название отдела"/>
            <TextBox Name="nameDepartamentTB"/>
            <Button Name="saveNewDepBtn" Content="Сохранить" Click="saveNewDepBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
