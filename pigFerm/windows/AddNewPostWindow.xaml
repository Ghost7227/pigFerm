<Window x:Class="pigFerm.windows.AddNewPostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="AddNewPostWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите отдел" Grid.Row="1"/>
        <ComboBox Name="departamentCB" Grid.Row="1" Grid.Column="1" DisplayMemberPath="nameDepartment"/>

        <TextBlock Text="Введите название" Grid.Row="2"/>
        <TextBox Name="nameTB" Grid.Row="2" Grid.Column="1"/>

        <TextBlock Text="Введите зарплату" Grid.Row="3"/>
        <TextBox Name="salaryTB" Grid.Row="3" Grid.Column="1" PreviewTextInput="salaryTB_PreviewTextInput" PreviewKeyDown="salaryTB_PreviewKeyDown"/>

        <Button Name="savePostBtn" Content="Сохранить" Click="savePostBtn_Click" Grid.Row="4" Grid.Column="1"/>

    </Grid>
</Window>
