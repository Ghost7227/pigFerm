<Window x:Class="pigFerm.windows.AddOrEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="AddOrEditProductWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Заполните данные: "/>

        <TextBlock Text="Выберите вид продукции: " Grid.Row="1"/>
        <ComboBox Name="typeProductCB" Grid.Column="1" Grid.Row="1">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding id}" Grid.Column="0"/>
                        <TextBlock Text="{Binding nameTypeProduct}" Grid.Column="1"/>
                        <TextBlock Text="{Binding unit}" Grid.Column="2"/>
                        <TextBlock Text="{Binding cost}" Grid.Column="3"/>
                    </Grid>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        
        <TextBlock Text="Укажите количество: " Grid.Row="2"/>
        <TextBox Name="quantityTB" Grid.Row="2" Grid.Column="1"/>

        <TextBlock Text="Выберите событие, в результате которого была получена продукция: " Grid.Row="3"/>
        <ComboBox Name="eventCB" Grid.Column="1" Grid.Row="3" DisplayMemberPath="typeAndDateEvent"/>

        <TextBlock Text="Выберите дату производства: " Grid.Row="4"/>
        <DatePicker Name="productionDateDP" SelectedDateFormat="Long" Grid.Row="4" Grid.Column="1"/>

        <TextBlock Text="Выберите дату окончания срока годности: " Grid.Row="5"/>
        <DatePicker Name="expirationDateDP" SelectedDateFormat="Long" Grid.Row="5" Grid.Column="1"/>


        <TextBlock Text="Заполните описание: " Grid.Row="6"/>
        <TextBox Name="descriptionTB" Grid.Row="6" Grid.Column="1"/>

        <Button Name="saveBtn" Content="Сохранить" Click="saveBtn_Click" Grid.Row="7" Grid.Column="1"/>
    </Grid>
</Window>
