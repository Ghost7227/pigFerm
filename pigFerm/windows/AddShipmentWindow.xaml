<Window x:Class="pigFerm.windows.AddShipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="AddShipmentWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition />
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Заполните данные:"/>
        
        <TextBlock Grid.Row="1" Text="Выберите контрагента:"/>
        <ComboBox Name="counterpartyCB" Grid.Row="1" Grid.Column="1" Grid.IsSharedSizeScope="True">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition SharedSizeGroup="col"/>
                            <ColumnDefinition SharedSizeGroup="col1"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding id}"/>
                        <TextBlock Text="{Binding nameCounterparties}" Grid.Column="1"/>
                    </Grid>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        
        <TextBlock Grid.Row="2" Text="Укажите дату:"/>
        <DatePicker Name="dp1" Grid.Row="2" Grid.Column="1"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2">
            <TextBlock Text="Выберите продукцию:"/>
            <ListView Name="prodLV" Grid.IsSharedSizeScope="True" ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition SharedSizeGroup="idCol"/>
                                <ColumnDefinition SharedSizeGroup="prodTypeCol"/>
                                <ColumnDefinition SharedSizeGroup="quantityCol"/>
                                <ColumnDefinition SharedSizeGroup="dateCol"/>
                                <ColumnDefinition SharedSizeGroup="dateCol"/>
                                <ColumnDefinition SharedSizeGroup="costCol"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding id}" Grid.Column="0"/>
                            <TextBlock Text="{Binding productType.nameTypeProduct}" Grid.Column="1"/>
                            <TextBlock Text="{Binding quantityUnit}" Grid.Column="2"/>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Произведен: "/>
                                <TextBlock Text="{Binding prodauctionDate, StringFormat='dd.MM.yyyy'}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Годен до: "/>
                                <TextBlock Text="{Binding expirationDate, StringFormat='dd.MM.yyyy'}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding costUnit}" Grid.Column="5"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <Button Name="saveBtn" Click="saveBtn_Click" Content="Сохранить" Grid.Row="4" Grid.Column="1"/>
    </Grid>
</Window>
