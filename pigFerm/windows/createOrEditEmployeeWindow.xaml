<Window x:Class="pigFerm.windows.createOrEditEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="createOrEditEmployeeWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Фамилия:"/>
        <TextBox Name="lastNameTB" Grid.Column="1"/>

        <TextBlock Grid.Row="1" Text="Имя:"/>
        <TextBox Name="firstNameTB" Grid.Column="1" Grid.Row="1"/>

        <TextBlock Grid.Row="2" Text="Отчество:"/>
        <StackPanel Grid.Column="1" Grid.Row="2">
            <TextBox Name="midleNameTB"/>
            <CheckBox Content="Отчество отсутствует" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Дата рождения:" TextWrapping="Wrap"/>
        <DatePicker Grid.Column="1" Grid.Row="3" SelectedDateFormat="Long" Name="bdDatePicker"/>

        <TextBlock Grid.Row="4" Text="Пол:"/>
        <StackPanel Grid.Column="1" Grid.Row="4">
            <RadioButton Content="Мужчина" Name="mGenderRB"/>
            <RadioButton Content="Женщина" Name="wGenderRB"/>
        </StackPanel>

        <TextBlock Grid.Row="5" Text="Серия и номер паспорта (без пробела):" TextWrapping="Wrap"/>
        <TextBox Name="pasportTB" Grid.Column="1" Grid.Row="5" PreviewTextInput="digit_PreviewTextInput" PreviewKeyDown="digit_PreviewKeyDown" MaxLength="10"/>

        <TextBlock Grid.Row="6" Text="СНИЛС (без пробелов и тире):" TextWrapping="Wrap"/>
        <TextBox Name="snilsTB" Grid.Column="1" Grid.Row="6" PreviewTextInput="digit_PreviewTextInput" PreviewKeyDown="digit_PreviewKeyDown" MaxLength="11"/>

        <TextBlock Grid.Row="7" Text="ИНН:"/>
        <TextBox Name="innTB" Grid.Column="1" Grid.Row="7" MaxLength="12" PreviewTextInput="digit_PreviewTextInput" PreviewKeyDown="digit_PreviewKeyDown"/>

        <TextBlock Grid.Row="8" Text="Электронная почта:" TextWrapping="Wrap"/>
        <TextBox Name="emailTB" Grid.Column="1" Grid.Row="8"/>

        <TextBlock Grid.Row="9" Text="Номер телефона (начиная с 8):" TextWrapping="Wrap"/>
        <TextBox Name="phoneTB" Grid.Column="1" Grid.Row="9" MaxLength="11" PreviewTextInput="digit_PreviewTextInput" PreviewKeyDown="digit_PreviewKeyDown"/>

        <TextBlock Grid.Row="10" Text="Должность:" TextWrapping="Wrap"/>
        <ComboBox Name="postCB" DisplayMemberPath="namePost" Grid.Column="1" Grid.Row="10"/>
        <Button Content="Сохранить" HorizontalAlignment="Right" Name="saveBtn" Click="SaveBtn_Click" Grid.Column="1" Grid.Row="11"/>
    </Grid>
</Window>
