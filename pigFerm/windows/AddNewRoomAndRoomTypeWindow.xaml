<Window x:Class="pigFerm.windows.AddNewRoomAndRoomTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="AddNewRoomAndRoomTypeWindow" Height="450" Width="800">
    <Grid>
        <Grid Name="createRoomGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Заполните данные:" Grid.ColumnSpan="2"/>
            
            <TextBlock Text="Тип помещения:" Grid.Row="1"/>
            <ComboBox Name="roomTypeCB" Grid.Column="1" Grid.Row="1" DisplayMemberPath="nameRoomTtpes"/>

            <TextBlock Text="Адрес помещения:" Grid.Row="2"/>
            <TextBox Name="adresTB" Grid.Row="2" Grid.Column="1"/>
            
            <TextBlock Text="Вместимость:" Grid.Row="3"/>
            <TextBox Name="capacityTB" Grid.Row="3" Grid.Column="1" PreviewTextInput="Number_PreviewTextInput" PreviewKeyDown="Number_PreviewKeyDown"/>
            
            <TextBlock Text="Текущее количество занятых мест:" Grid.Row="4"/>
            <TextBox Name="currentCountTB" Grid.Row="4" Grid.Column="1" PreviewTextInput="Number_PreviewTextInput" PreviewKeyDown="Number_PreviewKeyDown"/>
            
            <TextBlock Text="Описание помещения:" Grid.Row="5"/>
            <TextBox Name="locationNotesTB" Grid.Row="5" Grid.Column="1"/>

            <Button Content="Сохранить" Name="addNewRoomBtn" Click="addNewRoomBtn_Click" Grid.Column="1" Grid.Row="6"/>
        </Grid>
        <Grid Name="createRoomTypeGrid">
            <StackPanel>
                <TextBlock Text="Введите название типа помещений: "/>
                <TextBox Name="nameRoomTypeTB"/>
                <Button Name="addNewRoomTypeBtn" Content="Сохранить" Click="addNewRoomTypeBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
