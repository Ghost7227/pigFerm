<Window x:Class="pigFerm.windows.AddNewRoomAndRoomTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="AddNewRoomAndRoomTypeWindow" Height="450" Width="800">
    <Grid>
        <Grid Name="createRoomGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Тип помещения:" Grid.Row="0"/>
            <TextBlock Text="Адрес помещения:" Grid.Row="1"/>
            <TextBlock Text="Вместимость:" Grid.Row="2"/>
            <TextBlock Text="Текущее количество занятых мест:" Grid.Row="3"/>
            <TextBlock Text="Описание:" Grid.Row="4"/>
        </Grid>
        <Grid Name="createRoomTypeGrid">
            <StackPanel>
                <TextBlock Text="Введите название типа помещений: "/>
                <TextBox Name="nameRoomTypeTB"/>
                <Button Name="addNewRoomTypeBtn" Content="Сохранить" Click="addNewRoomTypeBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
