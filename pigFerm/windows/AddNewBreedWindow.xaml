<Window x:Class="pigFerm.windows.AddNewBreedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm.windows"
        mc:Ignorable="d"
        Title="Новая порода" Height="90" Width="160">
    <Grid>
        <StackPanel>
            <TextBlock Text="Введите название породы: "/>
            <TextBox Name="nameBreedTB"/>
            <Button Name="saveBreedBtn" Click="saveBreedBtn_Click" Content="Сохранить"/>
        </StackPanel>
    </Grid>
</Window>
