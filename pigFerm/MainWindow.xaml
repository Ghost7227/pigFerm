<Window x:Class="pigFerm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pigFerm"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" MinWidth="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Button Content="Сотрудники" Name="employeeBtn" Click="employeeBtn_Click"/>
            <Button Content="Отделы и должности" Name="postBtn" Click="postBtn_Click"/>
            <Button Content="Помещения" Name="roomBtn" Click="roomBtn_Click"/>
            <Button Content="Контрагенты" Name="counterpartyBtn" Click="counterpartyBtn_Click"/>
            <Button Content="События" Name="eventBtn" Click="eventBtn_Click"/>
            <Button Content="Животные" Name="animalBtn" Click="animalBtn_Click"/>
            <Button Content="Продукция" Name="productBtn" Click="productBtn_Click"/>
            <Button Content="Поставки контрагентам" Name="shipmentBtn" Click="shipmentBtn_Click"/>
        </StackPanel>

        <Frame Name="mainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>

        <!--<ListView Name="lv1">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding nameGroup}">Название</GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>-->
    </Grid>
</Window>
